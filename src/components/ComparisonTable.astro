---
interface Row {
  label: string;
  values: string[];
}

interface Props {
  products: string[];
  rows: Row[];
}

const { products, rows } = Astro.props;
---

<div class="comparison-table-wrap" role="region" aria-label="Tabela comparativa">
  <table class="comparison-table">
    <thead>
      <tr>
        <th scope="col">Critério</th>
        {products.map((p) => <th scope="col">{p}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <th scope="row">{row.label}</th>
          {row.values.map((v) => <td>{v}</td>)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
